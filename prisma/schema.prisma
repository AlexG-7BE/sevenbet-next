generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EditorialStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum CasinoImageKind {
  LOGO
  ICON
  HERO
  SCREENSHOT
  OTHER
}

enum CasinoCountryAvailability {
  AVAILABLE
  RESTRICTED
  NOT_AVAILABLE
  UNKNOWN
}

enum CasinoBonusType {
  WELCOME
  NO_DEPOSIT
  FREE_SPINS
  RELOAD
  CASHBACK
  VIP
  OTHER
}

enum CasinoAffiliateLinkType {
  OFFER
  OFFICIAL_SITE
  TERMS
  SUPPORT
  OTHER
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  REVIEWER
  AFFILIATE_MANAGER
  ANALYST
  SUPPORT
}

enum CmsBlockType {
  TEXT
  HEADING
  CALLOUT
  IMAGE
  VIDEO
  QUOTE
  CHECKLIST
  QUIZ
  SCENARIO
  EXERCISE
  REFLECTION
  PRACTICAL_TASK
  RESOURCE_LINK
  SUMMARY
  DIVIDER
  RESPONSIBLE_GAMBLING_NOTICE
  RELATED_COMPARISON
}

enum XpEventType {
  LESSON_COMPLETION
  STEP_COMPLETION
  QUIZ_COMPLETION
  QUIZ_PASSING
  SCENARIO_COMPLETION
  EXERCISE_COMPLETION
  PROGRAM_COMPLETION
  GUIDE_COMPLETION
}

model AdminUser {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @unique
  email     String    @unique
  name      String
  role      AdminRole @default(AUTHOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  auditLogs AuditLog[]
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions           Session[]
  accounts           Account[]
  adminUser          AdminUser?
  programEnrollments ProgramEnrollment[]
  xpEvents           UserXpEvent[]
  achievements       UserAchievement[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Program {
  id                           String          @id @default(uuid()) @db.Uuid
  slug                         String          @unique
  internalName                 String
  title                        String
  summary                      String
  introduction                 String
  estimatedTotalMinutes        Int
  language                     String          @default("en")
  difficulty                   String          @default("Beginner")
  coverImage                   String?
  xpCompletionReward           Int             @default(0)
  certificateEnabled           Boolean         @default(false)
  registrationRequirementPoint String          @default("NEVER")
  progressSavingBehavior       String          @default("LOCAL")
  completionRules              Json
  seoTitle                     String?
  seoDescription               String?
  socialImage                  String?
  canonicalUrl                 String?
  publishedVersion             Int             @default(0)
  draftVersion                 Int             @default(1)
  publishedAt                  DateTime?
  scheduledPublishAt           DateTime?
  status                       EditorialStatus @default(DRAFT)
  archivedAt                   DateTime?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  createdBy                    String
  updatedBy                    String

  steps       ProgramStep[]
  versions    ProgramVersion[]
  enrollments ProgramEnrollment[]
}

model ProgramStep {
  id                 String          @id @default(uuid()) @db.Uuid
  programId          String          @db.Uuid
  slug               String          @unique
  title              String
  shortTitle         String
  description        String
  learningObjective  String
  status             EditorialStatus @default(DRAFT)
  order              Int
  estimatedMinutes   Int
  xp                 Int             @default(0)
  completionMessage  String
  practicalTakeaway  String
  prerequisites      Json
  icon               String?
  visibility         String          @default("PUBLIC")
  unlockDelayHours   Int?
  relatedGuideIds    String[]
  relatedResourceIds String[]
  completionRules    Json
  archivedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String
  updatedBy          String

  program Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([programId, order])
}

model Lesson {
  id                        String          @id @default(uuid()) @db.Uuid
  programStepId             String          @db.Uuid
  slug                      String          @unique
  title                     String
  summary                   String
  objective                 String
  status                    EditorialStatus @default(DRAFT)
  order                     Int
  estimatedMinutes          Int
  xp                        Int             @default(0)
  required                  Boolean         @default(true)
  retryPolicy               String          @default("UNLIMITED")
  prerequisites             Json
  completionRules           Json
  takeaway                  String
  recap                     String[]
  relatedResourceIds        String[]
  allowCommercialReferences Boolean         @default(false)
  archivedAt                DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  createdBy                 String
  updatedBy                 String

  programStep ProgramStep   @relation(fields: [programStepId], references: [id], onDelete: Cascade)
  blocks      LessonBlock[]
}

model LessonBlock {
  id            String       @id @default(uuid()) @db.Uuid
  lessonId      String       @db.Uuid
  type          CmsBlockType
  order         Int
  internalLabel String
  required      Boolean      @default(false)
  archived      Boolean      @default(false)
  data          Json

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, order])
}

model ProgramVersion {
  id           String    @id @default(uuid()) @db.Uuid
  programId    String    @db.Uuid
  version      Int
  status       String
  snapshot     Json
  migrationMap Json?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  createdBy    String

  program     Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollments ProgramEnrollment[]

  @@unique([programId, version])
  @@index([programId, createdAt])
}

model ProgramEnrollment {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String
  programId        String    @db.Uuid
  programVersionId String    @db.Uuid
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  currentStepId    String?   @db.Uuid

  program        Program                @relation(fields: [programId], references: [id], onDelete: Restrict)
  programVersion ProgramVersion         @relation(fields: [programVersionId], references: [id], onDelete: Restrict)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  progressEvents ProgramProgressEvent[]

  @@unique([userId, programId])
  @@index([programVersionId])
}

model ProgramProgressEvent {
  id           String   @id @default(uuid()) @db.Uuid
  enrollmentId String   @db.Uuid
  entityId     String
  entityType   String
  eventType    String
  eventKey     String
  metadata     Json?
  createdAt    DateTime @default(now())

  enrollment ProgramEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, eventKey])
  @@index([enrollmentId, createdAt])
}

model XpRule {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique
  title          String
  eventType      XpEventType
  targetId       String?
  xp             Int
  active         Boolean         @default(true)
  effectiveStart DateTime?
  effectiveEnd   DateTime?
  awardKey       String          @unique
  status         EditorialStatus @default(DRAFT)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String
  updatedBy      String

  userXpEvents UserXpEvent[]
}

model UserXpEvent {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String
  ruleId        String?     @db.Uuid
  achievementId String?     @db.Uuid
  awardKey      String
  eventType     XpEventType
  xp            Int
  createdAt     DateTime    @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rule        XpRule?      @relation(fields: [ruleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  achievement Achievement? @relation(fields: [achievementId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, awardKey])
  @@index([userId, createdAt])
  @@index([ruleId])
  @@index([achievementId])
}

model Achievement {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique
  internalName   String          @unique
  title          String
  description    String
  icon           String
  category       String
  tier           String
  xpReward       Int             @default(0)
  active         Boolean         @default(true)
  hidden         Boolean         @default(false)
  triggerType    String
  triggerConfig  Json
  effectiveStart DateTime?
  effectiveEnd   DateTime?
  status         EditorialStatus @default(DRAFT)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String
  updatedBy      String

  userAchievements UserAchievement[]
  xpEvents         UserXpEvent[]
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String
  achievementId String   @db.Uuid
  awardKey      String
  awardedAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, awardKey])
  @@index([userId, awardedAt])
  @@index([achievementId])
}

model Article {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique
  title          String
  excerpt        String
  category       String
  tags           String[]
  status         EditorialStatus @default(DRAFT)
  bodyBlocks     Json
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  readingTime    String?
  difficulty     String?
  publishedAt    DateTime?
  lastReviewedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String
  updatedBy      String
}

model Casino {
  id                       String          @id @default(uuid()) @db.Uuid
  slug                     String          @unique
  internalName             String?
  title                    String
  domain                   String          @unique
  websiteUrl               String?
  operator                 String?
  tagline                  String?
  summary                  String?
  description              String?
  foundedYear              Int?
  language                 String          @default("en")
  languages                String[]        @default([])
  currencies               String[]        @default([])
  editorScore              Float?
  license                  String?
  country                  String?
  pros                     String[]        @default([])
  cons                     String[]        @default([])
  responsibleGamblingTools String[]        @default([])
  reviewBlocks             Json?
  status                   EditorialStatus @default(DRAFT)
  publishedVersion         Int             @default(0)
  draftVersion             Int             @default(1)
  publishedAt              DateTime?
  scheduledPublishAt       DateTime?
  lastReviewedAt           DateTime?
  archivedAt               DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  createdBy                String
  updatedBy                String

  bonuses        Bonus[]
  affiliateLinks AffiliateLink[]
  versions       CasinoVersion[]
  revisions      CasinoRevision[]
  images         CasinoImage[]
  countries      CasinoCountry[]
  licenses       CasinoLicense[]
  paymentMethods CasinoPaymentMethod[]
  gameProviders  CasinoGameProvider[]
  gameCategories CasinoGameCategory[]
  casinoBonuses  CasinoBonus[]
  casinoLinks    CasinoAffiliateLink[]
  seo            CasinoSeo?
}

model CasinoVersion {
  id           String          @id @default(uuid()) @db.Uuid
  casinoId     String          @db.Uuid
  version      Int
  status       EditorialStatus
  snapshot     Json
  migrationMap Json?
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())
  createdBy    String

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, version])
  @@index([casinoId, createdAt])
}

model CasinoRevision {
  id             String   @id @default(uuid()) @db.Uuid
  casinoId       String   @db.Uuid
  revisionNumber Int
  snapshot       Json
  summary        String
  createdBy      String
  createdAt      DateTime @default(now())

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, revisionNumber])
  @@index([casinoId, createdAt])
}

model CasinoImage {
  id        String          @id @default(uuid()) @db.Uuid
  casinoId  String          @db.Uuid
  kind      CasinoImageKind @default(OTHER)
  url       String
  alt       String
  width     Int?
  height    Int?
  sortOrder Int             @default(0)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([casinoId, kind, sortOrder])
}

model CasinoCountry {
  id           String                    @id @default(uuid()) @db.Uuid
  casinoId     String                    @db.Uuid
  countryCode  String
  availability CasinoCountryAvailability @default(UNKNOWN)
  minimumAge   Int?
  notes        String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, countryCode])
  @@index([countryCode, availability])
}

model CasinoLicense {
  id              String    @id @default(uuid()) @db.Uuid
  casinoId        String    @db.Uuid
  authority       String
  licenseNumber   String?
  jurisdiction    String?
  status          String    @default("UNKNOWN")
  verificationUrl String?
  issuedAt        DateTime?
  expiresAt       DateTime?
  lastVerifiedAt  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, authority, licenseNumber])
  @@index([authority, status])
}

model CasinoPaymentMethod {
  id                    String   @id @default(uuid()) @db.Uuid
  casinoId              String   @db.Uuid
  methodKey             String
  name                  String
  supportsDeposits      Boolean  @default(true)
  supportsWithdrawals   Boolean  @default(true)
  currencies            String[] @default([])
  minimumDeposit        Decimal? @db.Decimal(12, 2)
  minimumWithdrawal     Decimal? @db.Decimal(12, 2)
  maximumWithdrawal     Decimal? @db.Decimal(12, 2)
  depositProcessingTime String?
  withdrawalTime        String?
  fees                  String?
  crypto                Boolean  @default(false)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, methodKey])
  @@index([casinoId, sortOrder])
}

model CasinoGameProvider {
  id          String    @id @default(uuid()) @db.Uuid
  casinoId    String    @db.Uuid
  providerKey String
  name        String
  websiteUrl  String?
  gameCount   Int?
  liveCasino  Boolean   @default(false)
  verifiedAt  DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, providerKey])
  @@index([casinoId, sortOrder])
}

model CasinoGameCategory {
  id          String   @id @default(uuid()) @db.Uuid
  casinoId    String   @db.Uuid
  categoryKey String
  name        String
  gameCount   Int?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([casinoId, categoryKey])
  @@index([casinoId, sortOrder])
}

model CasinoBonus {
  id                  String          @id @default(uuid()) @db.Uuid
  casinoId            String          @db.Uuid
  slug                String          @unique
  title               String
  summary             String
  type                CasinoBonusType @default(OTHER)
  percentage          Decimal?        @db.Decimal(6, 2)
  minimumDeposit      Decimal?        @db.Decimal(12, 2)
  maximumBonus        Decimal?        @db.Decimal(12, 2)
  currency            String?
  freeSpins           Int?
  wageringMultiplier  Decimal?        @db.Decimal(6, 2)
  wageringText        String?
  eligibility         String?
  importantConditions String[]        @default([])
  termsUrl            String?
  startsAt            DateTime?
  expiresAt           DateTime?
  status              EditorialStatus @default(DRAFT)
  offerStatus         OfferStatus     @default(DRAFT)
  lastVerifiedAt      DateTime?
  sortOrder           Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  createdBy           String
  updatedBy           String

  casino         Casino                @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  affiliateLinks CasinoAffiliateLink[]

  @@index([casinoId, status, offerStatus])
  @@index([casinoId, sortOrder])
}

model CasinoAffiliateLink {
  id             String                  @id @default(uuid()) @db.Uuid
  casinoId       String                  @db.Uuid
  casinoBonusId  String?                 @db.Uuid
  slug           String                  @unique
  title          String
  type           CasinoAffiliateLinkType @default(OFFER)
  destinationUrl String
  countryCode    String?
  language       String?
  campaign       String?
  priority       Int                     @default(0)
  status         EditorialStatus         @default(DRAFT)
  effectiveStart DateTime?
  effectiveEnd   DateTime?
  lastVerifiedAt DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  createdBy      String
  updatedBy      String

  casino Casino       @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bonus  CasinoBonus? @relation(fields: [casinoBonusId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([casinoId, status, priority])
  @@index([casinoBonusId])
}

model CasinoSeo {
  id                String   @id @default(uuid()) @db.Uuid
  casinoId          String   @unique @db.Uuid
  title             String?
  description       String?
  canonicalUrl      String?
  robots            String   @default("index,follow")
  socialTitle       String?
  socialDescription String?
  socialImage       String?
  structuredData    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  casino Casino @relation(fields: [casinoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Bonus {
  id                 String          @id @default(uuid()) @db.Uuid
  casinoId           String          @db.Uuid
  slug               String          @unique
  title              String
  summary            String
  amount             Int?
  percentage         Int?
  minimumDeposit     Int?
  maximumBonus       Int?
  wageringMultiplier Int?
  termsUrl           String?
  status             EditorialStatus @default(DRAFT)
  offerStatus        OfferStatus     @default(DRAFT)
  lastVerifiedAt     DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String
  updatedBy          String

  casino         Casino          @relation(fields: [casinoId], references: [id], onDelete: Cascade)
  affiliateLinks AffiliateLink[]
}

model AffiliateLink {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique
  title          String
  destinationUrl String
  casinoId       String?         @db.Uuid
  bonusId        String?         @db.Uuid
  country        String?
  language       String?
  campaign       String?
  priority       Int             @default(0)
  status         EditorialStatus @default(DRAFT)
  effectiveStart DateTime?
  effectiveEnd   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String
  updatedBy      String

  casino Casino? @relation(fields: [casinoId], references: [id], onDelete: SetNull)
  bonus  Bonus?  @relation(fields: [bonusId], references: [id], onDelete: SetNull)
}

model ContentRevision {
  id             String   @id @default(uuid()) @db.Uuid
  entityType     String
  entityId       String
  revisionNumber Int
  snapshot       Json
  summary        String
  createdBy      String
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @db.Uuid
  action     String
  entityType String
  entityId   String
  summary    String
  metadata   Json?
  timestamp  DateTime @default(now())

  actor AdminUser @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([timestamp])
}

model MediaAsset {
  id        String   @id @default(uuid()) @db.Uuid
  url       String
  alt       String
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
